{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "*": ["modules/*"]
    }
  },
  "include": ["modules/**/*"],
  "exclude": ["node_modules", "**/*.test.ts"]
}